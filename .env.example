# ============================================
# VCRM Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# cp .env.example apps/crm/.env.local

# ---- Required ----

# Supabase project URL and anon key (from Supabase dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (from Supabase dashboard > Settings > API)
# Used for server-side operations (inviting users, notifications, audit log)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Optional: Liveblocks (Collaborative Editing) ----
# Required if modules.liveblocks is enabled in fund.config.ts
# Get your key at https://liveblocks.io

NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=your-liveblocks-key

# ---- Optional: Twilio (SMS Notifications) ----
# Required if modules.sms is enabled in fund.config.ts

TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ---- Optional: Anthropic (AI Rejection Emails) ----
# Required if modules.rejectionEmails is enabled in fund.config.ts

ANTHROPIC_API_KEY=your-anthropic-key

# ---- Optional: Webhook Security ----
# Secret to validate incoming webhook requests from your form provider

WEBHOOK_SECRET=your-webhook-secret
